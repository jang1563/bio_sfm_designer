{
  "artifact": "m6d_w2b_target_adaptive_exact_ltt_protocol",
  "version": 1,
  "status": "fit_input_lock_ready_awaiting_explicit_fit_approval_not_compute_authority",
  "objective": "Test whether a target-adaptive external trust gate can independently certify controlled false-accept routing on multiple fresh protein-complex targets.",
  "claim_scope": {
    "supported_if_successful": "target-adaptive multi-target gate viability",
    "never_supported_by_this_protocol": [
      "one universal pAE threshold transfers to every target",
      "zero-shot W2 generalization",
      "recertification of any previously evaluated panel"
    ],
    "current_v11_panel_role": "hypothesis_formation_only"
  },
  "fresh_target_contract": {
    "n_initial_targets": 8,
    "exclude_all_historical_registry_targets": true,
    "exclude_v11_new_representative_targets": [
      "10OP_ST",
      "10VB_IJ",
      "10YA_AB",
      "10ZO_AB",
      "11HK_BC",
      "11LT_HL",
      "11OV_hl",
      "11YO_vu",
      "11ZV_BA",
      "12RH_DC",
      "1A00_BA"
    ],
    "require_unique_source_pdb": true,
    "require_one_representative_per_sequence_cluster": true,
    "require_manifest_and_msa_sha_validation": true
  },
  "generation_stages": {
    "fit": {
      "records_per_target": 60,
      "seed_namespace": "w2b-fit-v1",
      "run_for": "all_initial_targets"
    },
    "certification": {
      "records_per_target": 60,
      "seed_namespace": "w2b-cert-v1",
      "run_for": "fit_eligible_targets_only"
    },
    "test": {
      "records_per_target": 60,
      "seed_namespace": "w2b-test-v1",
      "run_for": "fit_eligible_targets_only"
    },
    "candidate_overlap_allowed": false
  },
  "fit_stage_rule": {
    "target_alpha": 0.2,
    "signal_orientation": "lower_pae_interaction_is_better",
    "minimum_fit_accepts": 20,
    "ordered_modes": [
      {
        "mode": "trust_all",
        "condition": "fit empirical false-accept rate is at most target_alpha",
        "signal_claim": false
      },
      {
        "mode": "selective_pae",
        "condition": "fit has both classes, AUROC(-pAE_interaction to success) is at least 0.65, and a frozen threshold accepts at least minimum_fit_accepts with empirical false-accept rate at most target_alpha",
        "signal_claim": true
      },
      {
        "mode": "refuse",
        "condition": "neither prior mode qualifies",
        "signal_claim": false
      }
    ],
    "mode_order_is_locked": true
  },
  "certification_rule": {
    "method": "one_sided_clopper_pearson_exact",
    "target_alpha": 0.2,
    "panel_delta": 0.1,
    "multiplicity_correction": "bonferroni_over_all_8_initial_targets",
    "per_target_delta": 0.0125,
    "minimum_certification_accepts": 22,
    "certified_when": "the frozen fit-stage rule accepts at least 22 certification rows and its one-sided exact upper confidence bound is at most 0.2",
    "test_split_affects_certificate": false,
    "implementation_required_before_compute": false
  },
  "panel_decision_rule": {
    "success_status": "w2b_target_adaptive_viability_supported",
    "minimum_certified_targets": 3,
    "minimum_selective_pae_certified_targets": 1,
    "require_all_qc_and_provenance_checks": true,
    "failed_or_refused_targets_remain_in_denominator": true,
    "universal_w2_generalization_claim_allowed": false
  },
  "compute_budget": {
    "initial_fit_records": 480,
